Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    Если Не ЗначениеЗаполнено(ИТСервис) Тогда
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите ИТ-сервис!", , "ИТСервис");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Проверить, есть ли изменения (чтобы не записывать пустую запись)
    ЕстьИзменения = ЗначениеЗаполнено(Развитие) 
                    ИЛИ ЗначениеЗаполнено(Сопровождение)
                    ИЛИ ЗначениеЗаполнено(ПланПроектаВИСУП)
                    ИЛИ ЗначениеЗаполнено(КодВАРМРазработчика)
                    ИЛИ ЗначениеЗаполнено(Руководитель);
    
    Если Не ЕстьИзменения Тогда
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите хотя бы один изменяемый параметр!");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    Движения.ИТСервисы_ПараметрыИТСервисов.Записывать = Истина;
    Движения.ИТСервисы_ПараметрыИТСервисов.Очистить();
    
    // Получаем текущее состояние из регистра
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.НаРазвитии КАК НаРазвитии,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.НаСопровождении КАК НаСопровождении,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.ПланПроектаВИСУП КАК ПланПроектаВИСУП,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.КодВАРМРазработчика КАК КодВАРМРазработчика,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.Руководитель КАК Руководитель,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.ДоговорТП КАК ДоговорТП,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.ДорожнаяКарта КАК ДорожнаяКарта,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.ПриказОВводеВПЭ КАК ПриказОВводеВПЭ,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.ПаспортСервиса КАК ПаспортСервиса,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.Архитектура КАК Архитектура,
    |	ИТСервисы_ПараметрыИТСервисовСрезПоследних.БазаЗнаний КАК БазаЗнаний
    |ИЗ
    |	РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&ДатаДокумента, ИТСервис = &ИТСервис) КАК
    |		ИТСервисы_ПараметрыИТСервисовСрезПоследних";
    
    Запрос.УстановитьПараметр("ДатаДокумента", Дата - 1);  // Срез до документа, чтобы не учитывать будущие
    Запрос.УстановитьПараметр("ИТСервис", ИТСервис);
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    ТекущееСостояние = Новый Структура(
        "НаРазвитии, НаСопровождении, ПланПроектаВИСУП, КодВАРМРазработчика, Руководитель, ДоговорТП, ДорожнаяКарта, ПриказОВводеВПЭ, ПаспортСервиса, Архитектура, БазаЗнаний",
        Ложь, Ложь, Ложь, "", Неопределено, Неопределено, Ложь, Неопределено, Ложь, Ложь, Ложь);
    
    Если Выборка.Следующий() Тогда
        ЗаполнитьЗначенияСвойств(ТекущееСостояние, Выборка);
    КонецЕсли;
    
    // Создаём новую запись в регистр
    Запись = Движения.ИТСервисы_ПараметрыИТСервисов.Добавить();
    Запись.Период = Дата;
    Запись.ИТСервис = ИТСервис;
    
    // Копируем старое состояние
    ЗаполнитьЗначенияСвойств(Запись, ТекущееСостояние);
    
    // Применяем новые значения, если указаны
    Если ЗначениеЗаполнено(Развитие) Или Развитие = Ложь Тогда
        Запись.НаРазвитии = Развитие;
    КонецЕсли;
    
    Если ЗначениеЗаполнено(Сопровождение) Или Сопровождение = Ложь Тогда
        Запись.НаСопровождении = Сопровождение;
    КонецЕсли;
    
    Если ЗначениеЗаполнено(ПланПроектаВИСУП) Или ПланПроектаВИСУП = Ложь Тогда
        Запись.ПланПроектаВИСУП = ПланПроектаВИСУП;
    КонецЕсли;
    
    Если ЗначениеЗаполнено(КодВАРМРазработчика) Тогда
        Запись.КодВАРМРазработчика = КодВАРМРазработчика;
    КонецЕсли;
    
    Если ЗначениеЗаполнено(Руководитель) Тогда
        Запись.Руководитель = Руководитель;
    КонецЕсли;
    
    // Обновление справочника сервиса (последние параметры)
    СервисОбъект = ИТСервис.ПолучитьОбъект();
    ЗаполнитьЗначенияСвойств(СервисОбъект, Запись);  // Копируем в справочник для быстрого доступа
    СервисОбъект.Записать();
    
    // Связь с ресурсами (если смена на "НаРазвитии = Ложь" — списать загрузку)
    Если Запись.НаРазвитии = Ложь И ТекущееСостояние.НаРазвитии = Истина Тогда
        // Списать ресурсы — добавь расход в регистр ресурсов (если нужно)
        // Например, вызов модуля для списания
    КонецЕсли;
    
КонецПроцедуры