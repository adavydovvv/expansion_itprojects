// Модуль объекта документа РегистрацияДокументацииСервиса

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт

    // 1. Движения по документации (оставляем как было, только улучшаем)
    Движения.ИТСервисы_ДокументацияСервисов.Записывать = Истина;
    Движения.ИТСервисы_ДокументацияСервисов.Очистить();

    Если НЕ ЗначениеЗаполнено(ИТСервис) Тогда
        //ОбщегоНазначения.СообщитьПользователю("Не указан ИТ-сервис!", , "ИТСервис", "Объект", Отказ);
        Возврат;
    КонецЕсли;

    Для Каждого СтрокаТЧ Из ДокументацияСервиса Цикл
        Запись = Движения.ИТСервисы_ДокументацияСервисов.Добавить();
        Запись.Период          = МоментВремени();
        Запись.ИТСервис        = ИТСервис;
        Запись.ТипДокументации = СтрокаТЧ.ТипДокументации;

        Запись.Статус              = СтрокаТЧ.Статус;
        Запись.ДатаСоздания        = СтрокаТЧ.ДатаСоздания;
        Запись.НомерДокумента      = СтрокаТЧ.НомерДокумента;
        Запись.АвторДокумента      = ?(ЗначениеЗаполнено(СтрокаТЧ.АвторДокумента), 
                                       СтрокаТЧ.АвторДокумента, 
                                       ПараметрыСеанса.ТекущийПользователь);
        Запись.ОписаниеРеквизитов  = СтрокаТЧ.ОписаниеРеквизитов;
        Запись.ПутиИСсылки         = СтрокаТЧ.ПутиИСсылки;
        Запись.Примечание          = СтрокаТЧ.Примечание;
    КонецЦикла;


    // 2. Движения по параметрам сервиса — ВАРИАНТ А (самый надёжный)
    Движения.ИТСервисы_ПараметрыИТСервисов.Записывать = Истина;

    // Получаем состояние НА МОМЕНТ ДО этого документа
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    ПараметрыСрезПоследних.ДорожнаяКарта          КАК ДорожнаяКарта,
    |    ПараметрыСрезПоследних.ПаспортСервиса         КАК ПаспортСервиса,
    |    ПараметрыСрезПоследних.Архитектура            КАК Архитектура,
    |    ПараметрыСрезПоследних.БазаЗнаний             КАК БазаЗнаний,
    |    ПараметрыСрезПоследних.НаРазвитии             КАК Развитие,
    |    ПараметрыСрезПоследних.НаСопровождении        КАК Сопровождение,
    |    ПараметрыСрезПоследних.ПланПроектаВИСУП       КАК ПланПроектаВИСУП,
    |    ПараметрыСрезПоследних.КодВАРМРазработчика    КАК КодВАРМРазработчика
    |ИЗ
    |    РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&МоментДо, ИТСервис = &ИТСервис) КАК ПараметрыСрезПоследних
    |УПОРЯДОЧИТЬ ПО
    |    ПараметрыСрезПоследних.Период УБЫВ";
    
    Запрос.УстановитьПараметр("ИТСервис", ИТСервис);
    Запрос.УстановитьПараметр("МоментДо", Новый Граница(МоментВремени(), ВидГраницы.Исключая));

    Выборка = Запрос.Выполнить().Выбрать();
    Текущее = Новый Структура("ДорожнаяКарта,ПаспортСервиса,Архитектура,БазаЗнаний,НаРазвитии,НаСопровождении,ПланПроектаВИСУП,КодВАРМРазработчика");

    Если Выборка.Следующий() Тогда
        ЗаполнитьЗначенияСвойств(Текущее, Выборка);
    КонецЕсли;

    // Создаём новую запись
    ЗаписьПараметров = Движения.ИТСервисы_ПараметрыИТСервисов.Добавить();
    ЗаписьПараметров.Период    = Дата;
    ЗаписьПараметров.ИТСервис  = ИТСервис;
   

    // Копируем ВСЁ предыдущее состояние
    ЗаполнитьЗначенияСвойств(ЗаписьПараметров, Текущее);

    // Обновляем только те поля, которые есть в табличной части документа
    Для Каждого СтрокаТЧ Из ДокументацияСервиса Цикл
 
        Тип = СтрокаТЧ.ТипДокументации;
 
        Если Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.НайтиПоНаименованию("Дорожная карта") Тогда
            ЗаписьПараметров.ДорожнаяКарта = Истина;
        Иначе
         ЗаписьПараметров.ДорожнаяКарта = Ложь;
        КонецЕсли;
 
        Если Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.НайтиПоНаименованию("Паспорт ИТ-сервиса") Тогда
            ЗаписьПараметров.ПаспортСервиса = Истина;
        Иначе
         ЗаписьПараметров.ПаспортСервиса = Ложь;
        КонецЕсли;
 
        Если Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.НайтиПоНаименованию("Архитектура") Тогда
            ЗаписьПараметров.Архитектура = Истина;
        Иначе
         ЗаписьПараметров.Архитектура = Ложь;
        КонецЕсли;
 
        Если Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.НайтиПоНаименованию("База знаний") Тогда
            ЗаписьПараметров.БазаЗнаний = Истина;
        Иначе
         ЗаписьПараметров.БазаЗнаний = Ложь;
        КонецЕсли;
 
    КонецЦикла;

КонецПроцедуры


// ОБРАБОТКА ПРОВЕРКИ ЗАПОЛНЕНИЯ
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// 1. Проверяем, что таблица не пустая
	Если ДокументацияСервиса.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена табличная часть 'Документация сервиса'!";
		Сообщение.Поле = "ДокументацияСервиса";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	// 2. Проверяем Обязательную Документацию (Устав и т.д.)
	ПроверитьОбязательнуюДокументацию(Отказ);
	
КонецПроцедуры

// ВСПОМОГАТЕЛЬНАЯ ПРОЦЕДУРА
Процедура ПроверитьОбязательнуюДокументацию(Отказ)
	
	// Ищем все типы документации, где стоит галочка "Обязательная"
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Типы.Ссылка КАК ТипДокументации,
	|	Типы.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ИТСервисы_ТипыДокументацииСервисов КАК Типы
	|ГДЕ
	|	Типы.ОбязательнаяДокументация = ИСТИНА
	|	И Типы.Активна = ИСТИНА";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Ищем этот тип в табличной части нашего документа
		НайденныеСтроки = ДокументацияСервиса.НайтиСтроки(
			Новый Структура("ТипДокументации", Выборка.ТипДокументации)
		);
		
		// Если не нашли - ругаемся
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			ТекстСообщения = СтрШаблон(
				"Для сервиса обязательно должен быть зарегистрирован документ типа '%1'!",
				Выборка.Наименование
			);
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Поле = "ДокументацияСервиса";
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
			
			Отказ = Истина; 
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
