#Область ОбработкаПроведения

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт

	Если НЕ ЗначениеЗаполнено(ИТСервис) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Не указан ИТ-сервис!", 
			"ИТСервис", 
			"Объект", 
			Отказ
		);
		Возврат;
	КонецЕсли;
	
	Движения.ИТСервисы_ПараметрыИТСервисов.Записывать = Истина;
	Движения.ИТСервисы_ПараметрыИТСервисов.Очистить();
	ЗаписатьДвиженияПоПараметрамСервиса();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьДвиженияПоПараметрамСервиса()
	
	ПредыдущееСостояние = ПолучитьПредыдущееСостояниеПараметров();
	
	ЗаписьПараметров = Движения.ИТСервисы_ПараметрыИТСервисов.Добавить();
	ЗаписьПараметров.Период = Дата;
	ЗаписьПараметров.ИТСервис = ИТСервис;
	
	ЗаполнитьЗначенияСвойств(ЗаписьПараметров, ПредыдущееСостояние);
	
	ЗаписьПараметров.ДорожнаяКарта = Ложь;
	ЗаписьПараметров.ПаспортСервиса = Ложь;
	ЗаписьПараметров.Архитектура = Ложь;
	ЗаписьПараметров.БазаЗнаний = Ложь;
	
	Для Каждого СтрокаТЧ Из ДокументацияСервиса Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТипДокументации) Тогда
			Продолжить;
		КонецЕсли;
		
		Тип = СтрокаТЧ.ТипДокументации;
		
		Если Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.ДорожнаяКарта Тогда
			ЗаписьПараметров.ДорожнаяКарта = Истина;
		ИначеЕсли Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.ПаспортИТСервиса Тогда
			ЗаписьПараметров.ПаспортСервиса = Истина;
		ИначеЕсли Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.Архитектура Тогда
			ЗаписьПараметров.Архитектура = Истина;
		ИначеЕсли Тип = Справочники.ИТСервисы_ТипыДокументацииСервисов.БазаЗнаний Тогда
			ЗаписьПараметров.БазаЗнаний = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьПредыдущееСостояниеПараметров()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПараметрыСрезПоследних.ДорожнаяКарта КАК ДорожнаяКарта,
	|	ПараметрыСрезПоследних.ПаспортСервиса КАК ПаспортСервиса,
	|	ПараметрыСрезПоследних.Архитектура КАК Архитектура,
	|	ПараметрыСрезПоследних.БазаЗнаний КАК БазаЗнаний,
	|	ПараметрыСрезПоследних.ПриказОВводеВПЭ КАК ПриказОВводеВПЭ,
	|	ПараметрыСрезПоследних.ДоговорТП КАК ДоговорТП
	|ИЗ
	|	РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&МоментДо, ИТСервис = &ИТСервис) КАК ПараметрыСрезПоследних
	|УПОРЯДОЧИТЬ ПО
	|	ПараметрыСрезПоследних.Период УБЫВ";
	
	Запрос.УстановитьПараметр("ИТСервис", ИТСервис);
	Запрос.УстановитьПараметр("МоментДо", Новый Граница(МоментВремени(), ВидГраницы.Исключая));
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Состояние = Новый Структура;
	Состояние.Вставить("ДорожнаяКарта", Ложь);
	Состояние.Вставить("ПаспортСервиса", Ложь);
	Состояние.Вставить("Архитектура", Ложь);
	Состояние.Вставить("БазаЗнаний", Ложь);
	Состояние.Вставить("ПриказОВводеВПЭ", Неопределено);
	Состояние.Вставить("ДоговорТП", Неопределено);
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Состояние, Выборка);
	КонецЕсли;
	
	Возврат Состояние;
	
КонецФункции

#КонецОбласти

#Область ПроверкаЗаполнения

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если НЕ ЗначениеЗаполнено(ИТСервис) И ПроверяемыеРеквизиты.Содержит("ИТСервис") Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не указан ИТ-сервис!";
		Сообщение.Поле = "ИТСервис";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	Если ДокументацияСервиса.Количество() = 0 И ПроверяемыеРеквизиты.Содержит("ДокументацияСервиса") Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена табличная часть 'Документация сервиса'!";
		Сообщение.Поле = "ДокументацияСервиса";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	ПроверитьОбязательнуюДокументацию(Отказ);
	
КонецПроцедуры

Процедура ПроверитьОбязательнуюДокументацию(Отказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|    Типы.Ссылка КАК ТипДокументации,
	|    Типы.Наименование КАК Наименование
	|ИЗ
	|    Справочник.ИТСервисы_ТипыДокументацииСервисов КАК Типы
	|ГДЕ
	|    Типы.ОбязательнаяДокументация = ИСТИНА
	|    И Типы.Активна = ИСТИНА";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НайденныеСтроки = ДокументацияСервиса.НайтиСтроки(
			Новый Структура("ТипДокументации", Выборка.ТипДокументации)
		);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			ТекстСообщения = СтрШаблон(
				"Для сервиса обязательно должен быть зарегистрирован документ типа '%1'!",
				Выборка.Наименование
			);
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Поле = "ДокументацияСервиса";
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти