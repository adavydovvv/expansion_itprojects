&НаКлиенте
Процедура СоставСотрудникПриИзменении(Элемент)
	
	СтрокаСостава = Элементы.Состав.ТекущиеДанные;
	
	Если СтрокаСостава = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем, есть ли уже этот сотрудник во второй таблице, чтобы не дублировать
	ПараметрыОтбора = Новый Структура("Сотрудник", СтрокаСостава.Сотрудник);
	НайденныеСтроки = Объект.КомпетенцииСотрудников.НайтиСтроки(ПараметрыОтбора);
	
	// Если сотрудника еще нет во второй ТЧ и он заполнен в первой
	Если НайденныеСтроки.Количество() = 0 И ЗначениеЗаполнено(СтрокаСостава.Сотрудник) Тогда
		НоваяСтрокаКомпетенций = Объект.КомпетенцииСотрудников.Добавить();
		НоваяСтрокаКомпетенций.Сотрудник = СтрокаСостава.Сотрудник;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоставПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = Элементы.Состав.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		
		СотрудникДляУдаления = ТекущиеДанные.Сотрудник;
		
		// Ищем все строки с этим сотрудником во второй ТЧ
		ИндексСтроки = Объект.КомпетенцииСотрудников.Количество() - 1;
		Пока ИндексСтроки >= 0 Цикл
			Если Объект.КомпетенцииСотрудников[ИндексСтроки].Сотрудник = СотрудникДляУдаления Тогда
				Объект.КомпетенцииСотрудников.Удалить(ИндексСтроки);
			КонецЕсли;
			ИндексСтроки = ИндексСтроки - 1;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры