#Область ОбработкаПроведения

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	Движения.ИТСервисы_КомандыПроектов.Записывать = Истина;
	Движения.ИТСервисы_КомандыПроектов.Очистить();
	Движения.ИТСервисы_КомандыПроектов.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.Сотрудник КАК Сотрудник,
		|	ТЧ.РольВКоманде КАК РольВКоманде,
		|	СУММА(ТЧ.ВыделяемыеЧасы) КАК ЗапрашиваемыеЧасы
		|ПОМЕСТИТЬ ВТ_Участники
		|ИЗ
		|	Документ.ИТСервисы_ФормированиеКомандыПроекта.Участники КАК ТЧ
		|ГДЕ
		|	ТЧ.Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО
		|	ТЧ.Сотрудник,
		|	ТЧ.РольВКоманде
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Участники.Сотрудник КАК Сотрудник,
		|	ПРЕДСТАВЛЕНИЕ(ВТ_Участники.Сотрудник) КАК Имя,
		|	ВТ_Участники.РольВКоманде КАК РольВКоманде,
		|	ВТ_Участники.ЗапрашиваемыеЧасы КАК ЗапрашиваемыеЧасы,
		|	ЕСТЬNULL(Квалификация.НормаЧасовВМесяц, 0) КАК НормаЧасов,
		|	ЕСТЬNULL(Занятость.УжеЗанятЧасов, 0) КАК ТекущаяЗагрузкаЧасов
		|ИЗ
		|	ВТ_Участники КАК ВТ_Участники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИТСервисы_КвалификацияСотрудников.СрезПоследних(&Период, Сотрудник В
		|			(ВЫБРАТЬ
		|				ВТ_Участники.Сотрудник
		|			ИЗ
		|				ВТ_Участники КАК ВТ_Участники)) КАК Квалификация
		|		ПО ВТ_Участники.Сотрудник = Квалификация.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			Команды.Сотрудник КАК Сотрудник,
		|			СУММА(Команды.ЧасовНаПроекте) КАК УжеЗанятЧасов
		|		ИЗ
		|			РегистрСведений.ИТСервисы_КомандыПроектов.СрезПоследних(&Период, Сотрудник В
		|				(ВЫБРАТЬ
		|					ВТ_Участники.Сотрудник
		|				ИЗ
		|					ВТ_Участники КАК ВТ_Участники)
		|			И Проект <> &Проект) КАК Команды
		|		ГДЕ
		|			Команды.Проект.Статус <> ЗНАЧЕНИЕ(Перечисление.ИТСервисы_СтатусыПроектов.Завершен)
		|		СГРУППИРОВАТЬ ПО
		|			Команды.Сотрудник) КАК Занятость
		|		ПО ВТ_Участники.Сотрудник = Занятость.Сотрудник";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("Проект", Проект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СвободноЧасов = Выборка.НормаЧасов - Выборка.ТекущаяЗагрузкаЧасов;
		
		Если Выборка.ЗапрашиваемыеЧасы > СвободноЧасов Тогда
			ТекстОшибки = СтрШаблон(
				"Сотрудник %1 перегружен! Запрошено: %2 ч., Свободно: %3 ч. (Норма: %4 ч., Уже занят: %5 ч.)",
				Выборка.Имя, Выборка.ЗапрашиваемыеЧасы, СвободноЧасов, Выборка.НормаЧасов, Выборка.ТекущаяЗагрузкаЧасов
			);
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстОшибки;
			Сообщение.Сообщить();
			Отказ = Истина;
		ИначеЕсли НЕ Отказ Тогда
			Движение = Движения.ИТСервисы_КомандыПроектов.Добавить();
			Движение.Период = Дата;
			Движение.Проект = Проект;
			Движение.Сотрудник = Выборка.Сотрудник;
			Движение.РольВКоманде = Выборка.РольВКоманде;
			Движение.ЧасовНаПроекте = Выборка.ЗапрашиваемыеЧасы;
		КонецЕсли;		
	КонецЦикла;	
КонецПроцедуры

#КонецОбласти