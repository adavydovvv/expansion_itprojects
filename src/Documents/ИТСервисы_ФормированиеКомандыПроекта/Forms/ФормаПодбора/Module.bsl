&НаКлиенте
Процедура ВыбратьОтмеченных(Команда)
	МассивВозврата = Новый Массив;
	Для Каждого ИдентификаторСтроки Из Элементы.СписокСвободных.ВыделенныеСтроки Цикл
		ДанныеСтроки = Элементы.СписокСвободных.ДанныеСтроки(ИдентификаторСтроки);
		Если ДанныеСтроки <> Неопределено Тогда
			ПараметрыСотрудника = Новый Структура("Сотрудник, Роль", ДанныеСтроки.Сотрудник, ДанныеСтроки.Роль);
			МассивВозврата.Добавить(ПараметрыСотрудника);
		КонецЕсли;
	КонецЦикла;
	Если МассивВозврата.Количество() > 0 Тогда
		ОповеститьОВыборе(МассивВозврата);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписокСвободныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь; 
	ДанныеСтроки = Элемент.ТекущиеДанные;
	Если ДанныеСтроки = Неопределено Тогда Возврат; КонецЕсли;
	МассивВозврата = Новый Массив;
	МассивВозврата.Добавить(Новый Структура("Сотрудник, Роль", ДанныеСтроки.Сотрудник, ДанныеСтроки.Роль));
	ОповеститьОВыборе(МассивВозврата);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СписокСвободных.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	Если Параметры.Свойство("Проект") Тогда
		Проект = Параметры.Проект;
	КонецЕсли;
	Если Параметры.Свойство("УжеВыбранные") И Параметры.УжеВыбранные.Количество() > 0 Тогда
		МассивИсключений = Новый ФиксированныйМассив(Параметры.УжеВыбранные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Проект) Тогда
		СтрогийОтбор = Истина;
	КонецЕсли;
	ОбновитьОтборыНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура СтрогийОтборПриИзменении(Элемент)
	ОбновитьОтборыНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновитьОтборыНаСервере()
	СписокСвободных.Отбор.Элементы.Очистить();
	Если ТипЗнч(МассивИсключений) = Тип("ФиксированныйМассив") И МассивИсключений.Количество() > 0 Тогда
		ГруппаНЕ = СписокСвободных.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаНЕ.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаНе;
		ГруппаНЕ.Использование = Истина;
		ГруппаИЛИ = ГруппаНЕ.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаИЛИ.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		ГруппаИЛИ.Использование = Истина;

		Для Каждого ТекИсключение Из МассивИсключений Цикл
			ГруппаИ = ГруппаИЛИ.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
			ГруппаИ.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
			ГруппаИ.Использование = Истина;
	
			ЭлементСотр = ГруппаИ.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементСотр.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Сотрудник");
			ЭлементСотр.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементСотр.ПравоеЗначение = ТекИсключение.Сотрудник; // Заменили здесь
			ЭлементСотр.Использование = Истина;
			
			ЭлементРоль = ГруппаИ.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементРоль.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Роль");
			ЭлементРоль.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементРоль.ПравоеЗначение = ТекИсключение.Роль; // И заменили здесь
			ЭлементРоль.Использование = Истина;
		КонецЦикла;
	КонецЕсли;

	Если СтрогийОтбор И ЗначениеЗаполнено(Проект) Тогда
        Запрос = Новый Запрос;
        Запрос.Текст = 
            "ВЫБРАТЬ
            |	Квал.Сотрудник КАК Сотрудник,
            |	Квал.Роль КАК Роль,
            |	Квал.НормаЧасовВМесяц КАК Норма,
            |	ЕСТЬNULL(Занятость.УжеЗанято, 0) КАК Занято
            |ПОМЕСТИТЬ ВТ_Доступность
            |ИЗ
            |	РегистрСведений.ИТСервисы_КвалификацияСотрудников.СрезПоследних(&ТекущаяДата, ) КАК Квал
            |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
            |			Команды.Сотрудник КАК Сотрудник,
            |			Команды.РольВКоманде КАК Роль,
            |			СУММА(Команды.ЧасовНаПроекте) КАК УжеЗанято
            |		ИЗ
            |			РегистрСведений.ИТСервисы_КомандыПроектов.СрезПоследних(&ТекущаяДата, 
            |               Проект.Статус <> ЗНАЧЕНИЕ(Перечисление.ИТСервисы_СтатусыПроектов.Завершен)) КАК Команды
            |		СГРУППИРОВАТЬ ПО
            |			Команды.Сотрудник,
            |			Команды.РольВКоманде) КАК Занятость
            |		ПО Квал.Сотрудник = Занятость.Сотрудник
            |			И Квал.Роль = Занятость.Роль
            |;
            |
            |////////////////////////////////////////////////////////////////////////////////
            |ВЫБРАТЬ РАЗЛИЧНЫЕ
            |	ВТ.Сотрудник КАК Сотрудник
            |ИЗ
            |	ВТ_Доступность КАК ВТ
            |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИТСервисы_Проекты.ТребованияККоманде КАК Требования
            |		ПО ВТ.Роль = Требования.Роль
            |ГДЕ
            |	Требования.Ссылка = &Проект
            |	И (ВТ.Норма - ВТ.Занято) > 0"; // <-- ВОТ ГЛАВНОЕ УСЛОВИЕ

        Запрос.УстановитьПараметр("Проект", Проект);
        Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
        
        Результат = Запрос.Выполнить().Выгрузить();
        МассивПодходящих = Результат.ВыгрузитьКолонку("Сотрудник");

        ЭлементОтбора = СписокСвободных.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
        ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Сотрудник");
        ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
        ЭлементОтбора.ПравоеЗначение = МассивПодходящих;
        ЭлементОтбора.Использование = Истина;  
    КонецЕсли;	
КонецПроцедуры
