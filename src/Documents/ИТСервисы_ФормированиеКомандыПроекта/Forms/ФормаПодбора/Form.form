  <attributes>
    <name>СписокСвободных</name>
    <title>
      <key>ru</key>
      <value>Список свободных</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Квалификация.Сотрудник КАК Сотрудник,
	Квалификация.Роль КАК Роль,
	Квалификация.Грейд КАК Грейд,
	Квалификация.НормаЧасовВМесяц - ЕСТЬNULL(Занятость.УжеЗанятЧасов, 0) КАК СвободноЧасов
ИЗ
	РегистрСведений.ИТСервисы_КвалификацияСотрудников.СрезПоследних(&amp;ТекущаяДата, ) КАК Квалификация
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			Команды.Сотрудник КАК Сотрудник,
			СУММА(Команды.ЧасовНаПроекте) КАК УжеЗанятЧасов
		ИЗ
			РегистрСведений.ИТСервисы_КомандыПроектов.СрезПоследних(&amp;ТекущаяДата, ) КАК Команды
		ГДЕ
			Команды.Проект.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.ИТСервисы_СтатусыПроектов.Завершен)
		СГРУППИРОВАТЬ ПО
			Команды.Сотрудник) КАК Занятость
		ПО Квалификация.Сотрудник = Занятость.Сотрудник
ГДЕ
	Квалификация.НормаЧасовВМесяц - ЕСТЬNULL(Занятость.УжеЗанятЧасов, 0) > 0</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Сотрудник</dataPath>
        <field>Сотрудник</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Роль</dataPath>
        <field>Роль</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Проект</dataPath>
        <field>Проект</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Грейд</dataPath>
        <field>Грейд</field>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Грейд</value>
            </content>
          </localValue>
        </title>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СвободноЧасов</dataPath>
        <field>СвободноЧасов</field>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Свободно часов</value>
            </content>
          </localValue>
        </title>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>УжеЗанятЧасов</dataPath>
        <field>УжеЗанятЧасов</field>
      </fields>
      <parameters>
        <name>Период</name>
