#Область ОбработкаПроведения

Процедура ОбработкаПроведения(Отказ, Режим) Экспорт

    Движения.ИТСервисы_ДвижениеДоговоровСервисов.Записывать = Истина;

    СуммаИтого = УслугиДоговора.Итог("Стоимость");
    Если Сумма = 0 Тогда
        Сумма = СуммаИтого;
    КонецЕсли;

    Движение = Движения.ИТСервисы_ДвижениеДоговоровСервисов.Добавить();
    Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
    Движение.Период       = Дата;
    Движение.ТехПровайдер = ТехПровайдер;
    Движение.ВсегоДоговоров  = 1;
    Движение.СуммаДоговоров  = Сумма;
    Если СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Активен Тогда
        Движение.ДоговоровАктивных = 1;
    КонецЕсли;

	Движения.ИТСервисы_ПараметрыИТСервисов.Записывать = Истина;
    ЗаписатьДвижениеПоПараметрамСервиса_ДоговорТП();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьДвижениеПоПараметрамСервиса_ДоговорТП()

    ПредыдущееСостояние = ПолучитьПредыдущееСостояниеПараметров_ДоговорТП();

    ЗаписьПарам = Движения.ИТСервисы_ПараметрыИТСервисов.Добавить();
    ЗаписьПарам.Период   = Дата;
    ЗаполнитьЗначенияСвойств(ЗаписьПарам, ПредыдущееСостояние);

    ЗаписьПарам.ДоговорТП = Ссылка;

КонецПроцедуры

Функция ПолучитьПредыдущееСостояниеПараметров_ДоговорТП()

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |	Срез.ДорожнаяКарта КАК ДорожнаяКарта,
    |	Срез.ПриказОВводеВПЭ КАК ПриказОВводеВПЭ,
    |	Срез.ПаспортСервиса КАК ПаспортСервиса,
    |	Срез.Архитектура КАК Архитектура,
    |	Срез.БазаЗнаний КАК БазаЗнаний,
    |	Срез.ДоговорТП КАК ДоговорТП
    |ИЗ
    |	РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&МоментДо, ) КАК Срез
    |
    |УПОРЯДОЧИТЬ ПО
    |	Срез.Период УБЫВ";

    Запрос.УстановитьПараметр("МоментДо",
        Новый Граница(Дата, ВидГраницы.Исключая));

    Результат = Запрос.Выполнить();
    Выборка  = Результат.Выбрать();

    Сост = Новый Структура;
    Сост.Вставить("ДорожнаяКарта", Ложь);
    Сост.Вставить("ПриказОВводеВПЭ", Неопределено);
    Сост.Вставить("ПаспортСервиса", Ложь);
    Сост.Вставить("Архитектура", Ложь);
    Сост.Вставить("БазаЗнаний", Ложь);
    Сост.Вставить("ДоговорТП", Неопределено);

    Если Выборка.Следующий() Тогда
        ЗаполнитьЗначенияСвойств(Сост, Выборка);
    КонецЕсли;

    Возврат Сост;

КонецФункции



#КонецОбласти

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ЗначениеЗаполнено(ДатаОкончание) И ДатаОкончание < ДатаНачало Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Дата окончания не может быть раньше даты начала!";
		Сообщение.Поле = "ДатаОкончание";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		
		Отказ = Истина;
	КонецЕсли;
	
	Если УслугиДоговора.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена табличная часть 'Услуги договора'!";
		Сообщение.Поле = "УслугиДоговора";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

    Если ОбменДанными.Загрузка Тогда
        Возврат;
    КонецЕсли;

    Если УслугиДоговора.Количество() > 0 Тогда
        Сумма = УслугиДоговора.Итог("Стоимость");
    КонецЕсли;

    АктуализироватьСтатусДоговора();

КонецПроцедуры

Процедура АктуализироватьСтатусДоговора()
	
	ТекущаяДата = ТекущаяДата();
	
	Если ЗначениеЗаполнено(ДатаОкончание) Тогда
		РазницаДней = (ДатаОкончание - ТекущаяДата) / 86400;
		
		Если РазницаДней < 0 Тогда
			СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Истек;
		ИначеЕсли РазницаДней <= 30 Тогда
			СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Истекает;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#Область ОбработчикиСобытий

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	ГодСтрокой = Формат(ТекущаяДатаСеанса(), "ДФ=yy");
	Префикс = "ДД-" + ГодСтрокой + "-";
	
КонецПроцедуры

#КонецОбласти
