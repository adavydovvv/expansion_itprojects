// Модуль объекта документа ДоговорСТПровайдером

#Область ОбработкаПроведения

Процедура ОбработкаПроведения(Отказ, Режим) Экспорт

    // Существующий код движения по регистру накопления
    Движения.ИТСервисы_ДвижениеДоговоровСервисов.Записывать = Истина;

    СуммаИтого = УслугиДоговора.Итог("Стоимость");
    Если Сумма = 0 Тогда
        Сумма = СуммаИтого;
    КонецЕсли;

    Движение = Движения.ИТСервисы_ДвижениеДоговоровСервисов.Добавить();
    Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
    Движение.Период       = Дата;
    Движение.ИТСервис     = ИТСервис;
    Движение.ТехПровайдер = ТехПровайдер;
    Движение.ВсегоДоговоров  = 1;
    Движение.СуммаДоговоров  = Сумма;
    Если СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Активен Тогда
        Движение.ДоговоровАктивных = 1;
    КонецЕсли;

	Движения.ИТСервисы_ПараметрыИТСервисов.Записывать = Истина;
    ЗаписатьДвижениеПоПараметрамСервиса_ДоговорТП();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Копируем последнее состояние параметров и меняем только ДоговорТП
Процедура ЗаписатьДвижениеПоПараметрамСервиса_ДоговорТП()

    ПредыдущееСостояние = ПолучитьПредыдущееСостояниеПараметров_ДоговорТП();

    ЗаписьПарам = Движения.ИТСервисы_ПараметрыИТСервисов.Добавить();
    ЗаписьПарам.Период   = Дата;      // дата договора
    ЗаписьПарам.ИТСервис = ИТСервис;

    // имена ключей структуры совпадают с ресурсами регистра
    ЗаполнитьЗначенияСвойств(ЗаписьПарам, ПредыдущееСостояние);

    // перезаписываем только ДоговорТП
    ЗаписьПарам.ДоговорТП = Ссылка;

КонецПроцедуры


// Получаем последнюю запись регистра параметров по ИТ‑сервису
Функция ПолучитьПредыдущееСостояниеПараметров_ДоговорТП()

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |	Срез.ДорожнаяКарта КАК ДорожнаяКарта,
    |	Срез.ПриказОВводеВПЭ КАК ПриказОВводеВПЭ,
    |	Срез.ПаспортСервиса КАК ПаспортСервиса,
    |	Срез.Архитектура КАК Архитектура,
    |	Срез.БазаЗнаний КАК БазаЗнаний,
    |	Срез.ДоговорТП КАК ДоговорТП
    |ИЗ
    |	РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&МоментДо, ИТСервис = &ИТСервис) КАК Срез
    |
    |УПОРЯДОЧИТЬ ПО
    |	Срез.Период УБЫВ";

    Запрос.УстановитьПараметр("ИТСервис", ИТСервис);
    // ВАЖНО: используем дату документа, а не ТекущаяДата()
    Запрос.УстановитьПараметр("МоментДо",
        Новый Граница(Дата, ВидГраницы.Исключая));

    Результат = Запрос.Выполнить();
    Выборка  = Результат.Выбрать();

    // Структура с ИМЕНАМИ КАК В РЕГИСТРЕ
    Сост = Новый Структура;
    Сост.Вставить("ДорожнаяКарта", Ложь);
    Сост.Вставить("ПриказОВводеВПЭ", Неопределено);
    Сост.Вставить("ПаспортСервиса", Ложь);
    Сост.Вставить("Архитектура", Ложь);
    Сост.Вставить("БазаЗнаний", Ложь);
    Сост.Вставить("ДоговорТП", Неопределено);

    Если Выборка.Следующий() Тогда
        ЗаполнитьЗначенияСвойств(Сост, Выборка);
    КонецЕсли;

    Возврат Сост;

КонецФункции



#КонецОбласти

// ОБРАБОТКА ПРОВЕРКИ ЗАПОЛНЕНИЯ
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Проверяем дату окончания
	Если ЗначениеЗаполнено(ДатаОкончание) И ДатаОкончание < ДатаНачало Тогда
		// ИСПРАВЛЕНИЕ: Используем стандартный метод
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Дата окончания не может быть раньше даты начала!";
		Сообщение.Поле = "ДатаОкончание";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		
		Отказ = Истина;
	КонецЕсли;
	
	// Проверяем табличную часть
	Если УслугиДоговора.Количество() = 0 Тогда
		// ИСПРАВЛЕНИЕ: Используем стандартный метод
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена табличная часть 'Услуги договора'!";
		Сообщение.Поле = "УслугиДоговора";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

// ОБРАБОТКА ЗАПОЛНЕНИЯ
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	// Если создаём на основании другого документа
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ИТСервисы_ДоговорСТехническимПровайдером") Тогда
		
		// Копируем данные из старого договора
		ИТСервис = ДанныеЗаполнения.ИТСервис;
		ТехПровайдер = ДанныеЗаполнения.ТехПровайдер;
		ТипДоговора = ДанныеЗаполнения.ТипДоговора;
		
		// Дата начала = дата окончания старого договора + 1 день
		Если ЗначениеЗаполнено(ДанныеЗаполнения.ДатаОкончание) Тогда
			ДатаНачало = ДанныеЗаполнения.ДатаОкончание + 86400; // +1 день
		КонецЕсли;
		
		// Копируем табличную часть
		УслугиДоговора.Загрузить(ДанныеЗаполнения.УслугиДоговора.Выгрузить());
		
	КонецЕсли;
	
КонецПроцедуры

// ПЕРЕД ЗАПИСЬЮ
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

    Если ОбменДанными.Загрузка Тогда
        Возврат;
    КонецЕсли;

    Если НЕ ИТСервис.ВнешнийСервис Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = "Договор с техническим провайдером можно создавать только для внешних сервисов!";
        Сообщение.Поле = "ИТСервис";
        Сообщение.УстановитьДанные(ЭтотОбъект);
        Сообщение.Сообщить();
        Отказ = Истина;
        Возврат;
    КонецЕсли;

    // Автоматически заполняем ТехПровайдер из сервиса, если пусто
    Если НЕ ЗначениеЗаполнено(ТехПровайдер) Тогда
        ТехПровайдер = ИТСервис.Контрагент;
    КонецЕсли;

    // Автосумма
    Если УслугиДоговора.Количество() > 0 Тогда
        Сумма = УслугиДоговора.Итог("Стоимость");
    КонецЕсли;

    АктуализироватьСтатусДоговора();

КонецПроцедуры

Процедура АктуализироватьСтатусДоговора()
	
	ТекущаяДата = ТекущаяДата();
	
	// Если дата окончания близка (< 30 дней) - статус "Истекает"
	Если ЗначениеЗаполнено(ДатаОкончание) Тогда
		РазницаДней = (ДатаОкончание - ТекущаяДата) / 86400;
		
		Если РазницаДней < 0 Тогда
			СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Истек;
		ИначеЕсли РазницаДней <= 30 Тогда
			СтатусДоговора = Перечисления.ИТСервисы_СтатусыДоговоров.Истекает;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
