&НаКлиенте
Процедура ЗаполнитьИзКарточки(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ИТСервис) Тогда
		Сообщить("Сначала выберите ИТ-сервис!");
		Возврат;
	КонецЕсли;
	
	ЗаполнитьИзКарточкиНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзКарточкиНаСервере()
	
	// Читаем данные из справочника ИТ-сервисы
	// (Предполагаем, что там осталась табличная часть ПрогнозПодключения)
	
	СервисСсылка = Объект.ИТСервис;
	
	// Запрос к ТЧ справочника
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.Предприятие КАК ОрганизацияПолучатель,
		|	ТЧ.ДатаПрогноза КАК ДатаЗапуска
		|ИЗ
		|	Справочник.ИТСервисы_ИТСервисы.ПрогнозПодключения КАК ТЧ
		|ГДЕ
		|	ТЧ.Ссылка = &Ссылка";
		
	Запрос.УстановитьПараметр("Ссылка", СервисСсылка);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Сообщить("В карточке сервиса нет данных о прогнозе подключения.");
		Возврат;
	КонецЕсли;
	
	// Очищаем и заполняем
	Объект.ЭтапыПодключения.Очистить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НовСтр = Объект.ЭтапыПодключения.Добавить();
		НовСтр.ОрганизацияПолучатель = Выборка.ОрганизацияПолучатель;
		НовСтр.ДатаЗапуска = Выборка.ДатаЗапуска;
		// Дата начала по умолчанию = за 3 месяца до запуска
		НовСтр.ДатаНачала = ДобавитьМесяц(Выборка.ДатаЗапуска, -3); 
	КонецЦикла;
	
КонецПроцедуры
