Функция TasksSyncPOST(Запрос)

	Попытка
		Данные = ИТСервисы_ИТСервисыИнтеграцияСервер.ПрочитатьJSONИзТела(Запрос);
		Успех = ИТСервисы_ИТСервисыИнтеграцияСервер.ОбновитьПоляСинхронизации(Данные);

		Ответ = Новый Структура;

		Если НЕ Успех Тогда
			Ответ.Вставить("success", Ложь);
			Ответ.Вставить("message", "Строка задачи по uuid не найдена");
			Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(404, Ответ);
		КонецЕсли;

		Ответ.Вставить("success", Истина);
		Ответ.Вставить("message", "Поля синхронизации обновлены");
		Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(200, Ответ);

	Исключение
		Ошибка = Новый Структура;
		Ошибка.Вставить("success", Ложь);
		Ошибка.Вставить("message", ОписаниеОшибки());
		Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(500, Ошибка);
	КонецПопытки;

КонецФункции


Функция TasksFromKaitenPOST(Запрос)

	Попытка
		Данные = ИТСервисы_ИТСервисыИнтеграцияСервер.ПрочитатьJSONИзТела(Запрос);
		UUIDСтроки = ИТСервисы_ИТСервисыИнтеграцияСервер.СоздатьИлиОбновитьЗадачуИзKaiten(Данные);

		Ответ = Новый Структура;

		Если ПустаяСтрока(UUIDСтроки) Тогда
			Ответ.Вставить("success", Истина);
			Ответ.Вставить("ignored", Истина);
			Ответ.Вставить("message", "Карточка Kaiten не связана ни с одной строкой 1С, пропущено");
			Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(200, Ответ);
		КонецЕсли;

		Ответ.Вставить("success", Истина);
		Ответ.Вставить("ignored", Ложь);
		Ответ.Вставить("uuid", UUIDСтроки);
		Ответ.Вставить("message", "Изменения из Kaiten применены");
		Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(200, Ответ);

	Исключение
		Ошибка = Новый Структура;
		Ошибка.Вставить("success", Ложь);
		Ошибка.Вставить("message", ОписаниеОшибки());
		Возврат ИТСервисы_ИТСервисыИнтеграцияСервер.СформироватьJSONОтвет(500, Ошибка);
	КонецПопытки;

КонецФункции

