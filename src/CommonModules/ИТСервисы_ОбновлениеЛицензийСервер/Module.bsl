#Область ПрограммныйИнтерфейс

// Обновляет количество дней до окончания лицензии в регистре состояний лицензий
// Вызывается фоновым регламентным заданием
Процедура ОбновитьДниДоОкончанияЛицензий() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|   ИТСервисы_ЛицензииПО.Ссылка КАК Лицензия,
		|   ИТСервисы_ЛицензииПО.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|   Справочник.ИТСервисы_ЛицензииПО КАК ИТСервисы_ЛицензииПО
		|ГДЕ
		|   ИТСервисы_ЛицензииПО.ДатаОкончания <> &ПустаяДата";
	
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1, 1, 1));

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	СекундВДне = 86400;
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Пока Выборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.ИТСервисы_СостоянияЛицензий.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Лицензия.Установить(Выборка.Лицензия);
		НаборЗаписей.Прочитать();
		
		// Отбрасываем время для точного расчета целых дней
		ДнейДоОкончания = Цел((НачалоДня(Выборка.ДатаОкончания) - НачалоДня(ТекущаяДата)) / СекундВДне);
		
		Если НаборЗаписей.Количество() = 0 Тогда
			ЗаписьРегистра = НаборЗаписей.Добавить();
			ЗаписьРегистра.Лицензия = Выборка.Лицензия;
		Иначе
			ЗаписьРегистра = НаборЗаписей[0];
		КонецЕсли;
		
		ЗаписьРегистра.ДнейДоОкончания = ДнейДоОкончания;
		НаборЗаписей.Записать(Истина);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти