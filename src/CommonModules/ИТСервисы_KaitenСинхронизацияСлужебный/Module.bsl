	Возврат Ложь;

КонецФункции


Процедура ИсправитьДублиUUID() Экспорт

	ВстреченныеUUID = Новый Соответствие;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задачи КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();
		НужноЗаписать = Ложь;
		
		// Если ТЧ вообще пустая (для старых документов)
		Если ОбъектДокумента.ИнтеграционныйКонтур.Количество() = 0 Тогда
			НоваяСтрока = ОбъектДокумента.ИнтеграционныйКонтур.Добавить();
			НоваяСтрока.UUIDСтроки = Строка(Новый УникальныйИдентификатор());
			НоваяСтрока.ИзмененПослеСинхронизации = Истина;
			НужноЗаписать = Истина;
		Иначе
			Для Каждого СтрокаЗадачи Из ОбъектДокумента.ИнтеграционныйКонтур Цикл

				ТекущийUUID = БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки);

				Если ПустаяСтрока(ТекущийUUID) Тогда
					СтрокаЗадачи.UUIDСтроки = Строка(Новый УникальныйИдентификатор());
					СтрокаЗадачи.ИзмененПослеСинхронизации = Истина;
					НужноЗаписать = Истина;
				ИначеЕсли ВстреченныеUUID.Получить(ТекущийUUID) <> Неопределено Тогда
					СтрокаЗадачи.UUIDСтроки = Строка(Новый УникальныйИдентификатор());
					СтрокаЗадачи.ИзмененПослеСинхронизации = Истина;
					НужноЗаписать = Истина;
				Иначе
					ВстреченныеUUID.Вставить(ТекущийUUID, Истина);
					Если НЕ СтрокаЗадачи.ИзмененПослеСинхронизации Тогда
						СтрокаЗадачи.ИзмененПослеСинхронизации = Истина;
						НужноЗаписать = Истина;
					КонецЕсли;
				КонецЕсли;

			КонецЦикла;
		КонецЕсли;

		Если НужноЗаписать Тогда
			ОбъектДокумента.ДополнительныеСвойства.Вставить("ЭтоСлужебнаяЗаписьИнтеграции", Истина);
			ОбъектДокумента.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры
