Функция ПолучитьГлобальныеНастройкиИнтеграцииKaiten() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("enabled", Константы.ИТСервисы_KaitenIntegrationEnabled.Получить());
	Результат.Вставить("kaiten_base_url", СокрЛП(Константы.ИТСервисы_KaitenBaseUrl.Получить()));
	Результат.Вставить("kaiten_token", СокрЛП(Константы.ИТСервисы_KaitenToken.Получить()));
	Результат.Вставить("python_service_url", СокрЛП(Константы.ИТСервисы_PythonServiceUrl.Получить()));
	Результат.Вставить("sync_interval_minutes", Константы.ИТСервисы_KaitenSyncIntervalMinutes.Получить());

	Возврат Результат;

КонецФункции

Процедура ВыполнитьЗапускСинхронизацииKaiten() Экспорт
	
	URLСервиса = СокрЛП(Константы.ИТСервисы_PythonServiceUrl.Получить());

	Если ПустаяСтрока(URLСервиса) Тогда
		ВызватьИсключение "Не заполнена константа PythonServiceUrl.";
	КонецЕсли;

	ПараметрыURL = РазобратьURL(URLСервиса);

	Попытка
		Соединение = Новый HTTPСоединение(ПараметрыURL.Хост, ПараметрыURL.Порт);
		Запрос = Новый HTTPЗапрос(ПараметрыURL.Путь + "/sync/run");
		Запрос.Заголовки.Вставить("Content-Type", "application/json");
		Запрос.УстановитьТелоИзСтроки("{}", КодировкаТекста.UTF8);

		Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();

		Если Ответ.КодСостояния = 200 Тогда
			Возврат;
		ИначеЕсли Ответ.КодСостояния = 409 Тогда
			ВызватьИсключение "Синхронизация уже выполняется.";
		Иначе
			ВызватьИсключение
				"Ошибка запуска синхронизации. Код: "
				+ Строка(Ответ.КодСостояния)
				+ ". Ответ сервиса: "
				+ ТелоОтвета;
		КонецЕсли;

	Исключение
		ВызватьИсключение "Не удалось запустить синхронизацию: " + ОписаниеОшибки();
	КонецПопытки;

КонецПроцедуры

Функция РазобратьURL(Знач СтрокаURL) Экспорт

	СтрокаURL = СокрЛП(СтрокаURL);

	Схема = "";
	ПозицияСхемы = Найти(СтрокаURL, "://");
	Если ПозицияСхемы > 0 Тогда
		Схема = НРег(Лев(СтрокаURL, ПозицияСхемы - 1));
		СтрокаURL = Сред(СтрокаURL, ПозицияСхемы + 3);
	КонецЕсли;

	Путь = "";
	ПозицияСлеша = Найти(СтрокаURL, "/");
	Если ПозицияСлеша > 0 Тогда
		СтрокаСоединения = Лев(СтрокаURL, ПозицияСлеша - 1);
		Путь = Сред(СтрокаURL, ПозицияСлеша);
	Иначе
		СтрокаСоединения = СтрокаURL;
		Путь = "";
	КонецЕсли;

	Хост = СтрокаСоединения;
	Порт = 0;

	ПозицияДвоеточия = Найти(СтрокаСоединения, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Хост = Лев(СтрокаСоединения, ПозицияДвоеточия - 1);
		Порт = Число(Сред(СтрокаСоединения, ПозицияДвоеточия + 1));
	Иначе
		Если Схема = "https" Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
	КонецЕсли;

	Возврат Новый Структура("Схема,Хост,Порт,Путь", Схема, Хост, Порт, Путь);

КонецФункции

Функция СформироватьJSONОтвет(КодСостояния, Данные) Экспорт

	Ответ = Новый HTTPСервисОтвет(КодСостояния);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	ТекстJSON = ЗаписьJSON.Закрыть();

	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ТекстJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);

	Возврат Ответ;

КонецФункции


Функция ПрочитатьJSONИзТела(Запрос) Экспорт

	ТекстJSON = Запрос.ПолучитьТелоКакСтроку();

	Если ПустаяСтрока(ТекстJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Данные = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();

	Возврат Данные;

КонецФункции


Функция БезопаснаяСтрока(Значение) Экспорт

	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Попытка

		Если НЕ ЗначениеЗаполнено(Значение) Тогда
			Возврат "";
		КонецЕсли;

		Результат = СокрЛП(Строка(Значение));

		Если Найти(Результат, "<Объект не найден>") > 0 Тогда
			Возврат "";
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции


Функция ФорматДатаВJSON(ДатаЗначения) Экспорт

	Если НЕ ЗначениеЗаполнено(ДатаЗначения) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Формат(ДатаЗначения, "ДФ='yyyy-MM-ddTHH:mm:ss'");

КонецФункции


Процедура ЗаписатьДокументТехнически(ОбъектДокумента) Экспорт

	ОбъектДокумента.ДополнительныеСвойства.Вставить("ЭтоСлужебнаяЗаписьИнтеграции", Истина);

	Попытка
		Если ОбъектДокумента.Проведен Тогда
			ОбъектДокумента.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ОбъектДокумента.Записать();
		КонецЕсли;
	Исключение
		ОбъектДокумента.ДополнительныеСвойства.Вставить("ЭтоСлужебнаяЗаписьИнтеграции", Ложь);
		ВызватьИсключение;
	КонецПопытки;

	ОбъектДокумента.ДополнительныеСвойства.Вставить("ЭтоСлужебнаяЗаписьИнтеграции", Ложь);

КонецПроцедуры


Процедура ЗаписатьДокументСПроведением(ОбъектДокумента) Экспорт

	ЗаписатьДокументТехнически(ОбъектДокумента);

КонецПроцедуры


Функция НужноВыгружатьСтроку(СтрокаЗадачи) Экспорт

	UUIDСтроки = БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки);
	KaitenID = БезопаснаяСтрока(СтрокаЗадачи.KaitenID);

	Если ПустаяСтрока(UUIDСтроки) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ПустаяСтрока(KaitenID) Тогда
		Возврат Истина;
	КонецЕсли;

	Если СтрокаЗадачи.ИзмененПослеСинхронизации Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции


Функция ПолучитьЗаголовокЗадачи(СтрокаЗадачи) Экспорт

	Описание = БезопаснаяСтрока(СтрокаЗадачи.Описание);

	Если ПустаяСтрока(Описание) Тогда
		Возврат "Задача без названия";
	КонецЕсли;

	Возврат Лев(Описание, 120);

КонецФункции


Процедура ПопытатьсяЗаполнитьСтатус1СИзВнешнегоСтатуса(СтрокаЗадачи, ВнешнийСтатус) Экспорт

	ВнешнийСтатус = БезопаснаяСтрока(ВнешнийСтатус);

	Если ПустаяСтрока(ВнешнийСтатус) Тогда
		Возврат;
	КонецЕсли;

	Если ВнешнийСтатус = "Очередь" Или ВнешнийСтатус = "Новая" Тогда
		СтрокаЗадачи.Статус = Перечисления.ИТСервисы_СтатусыЗадач.Новая;
		Возврат;
	КонецЕсли;

	Если ВнешнийСтатус = "В работе" Тогда
		СтрокаЗадачи.Статус = Перечисления.ИТСервисы_СтатусыЗадач.ВРаботе;
		Возврат;
	КонецЕсли;

	Если ВнешнийСтатус = "На проверке" Тогда
		СтрокаЗадачи.Статус = Перечисления.ИТСервисы_СтатусыЗадач.НаПроверке;
		Возврат;
	КонецЕсли;

	Если ВнешнийСтатус = "Готово" Тогда
		СтрокаЗадачи.Статус = Перечисления.ИТСервисы_СтатусыЗадач.Завершена;
		Возврат;
	КонецЕсли;

	Если ВнешнийСтатус = "Отменено" Тогда
		СтрокаЗадачи.Статус = Перечисления.ИТСервисы_СтатусыЗадач.Отменена;
		Возврат;
	КонецЕсли;

КонецПроцедуры



Функция ПолучитьИзмененныеЗадачи() Экспорт

	МассивЗадач = Новый Массив;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задача КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();

		Если ОбъектДокумента.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаЗадачи Из ОбъектДокумента.Задачи Цикл

			Если НЕ НужноВыгружатьСтроку(СтрокаЗадачи) Тогда
				Продолжить;
			КонецЕсли;

			Стр = Новый Структура;
			Стр.Вставить("document_ref", Строка(ОбъектДокумента.Ссылка.УникальныйИдентификатор()));
			Стр.Вставить("row_number", СтрокаЗадачи.НомерСтроки);
			Стр.Вставить("uuid", БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки));
			Стр.Вставить("title", ПолучитьЗаголовокЗадачи(СтрокаЗадачи));
			Стр.Вставить("description", БезопаснаяСтрока(СтрокаЗадачи.Описание));
			Стр.Вставить("start_date", ФорматДатаВJSON(СтрокаЗадачи.ДатаНачала));
			Стр.Вставить("end_date", ФорматДатаВJSON(СтрокаЗадачи.ДатаОкончания));
			Стр.Вставить("planned_hours", СтрокаЗадачи.ПлановаяТрудоемкость);
			Стр.Вставить("actual_hours", СтрокаЗадачи.ФактическаяТрудоемкость);
			Стр.Вставить("kaiten_id", БезопаснаяСтрока(СтрокаЗадачи.KaitenID));
			Стр.Вставить("external_status", БезопаснаяСтрока(СтрокаЗадачи.ВнешнийСтатус));
			Стр.Вставить("kaiten_card_url", БезопаснаяСтрока(СтрокаЗадачи.KaitenCardURL));
			Стр.Вставить("service", БезопаснаяСтрока(СтрокаЗадачи.ИТСервис));
			Стр.Вставить("assignee", БезопаснаяСтрока(СтрокаЗадачи.Исполнитель));
			Стр.Вставить("status", БезопаснаяСтрока(СтрокаЗадачи.Статус));
			Стр.Вставить("priority", БезопаснаяСтрока(СтрокаЗадачи.Приоритет));

			МассивЗадач.Добавить(Стр);

		КонецЦикла;

	КонецЦикла;

	Возврат МассивЗадач;

КонецФункции


Функция ОбновитьПоляСинхронизации(Данные) Экспорт

	UUIDСтроки = "";
	KaitenID = "";
	ВнешнийСтатус = "";
	KaitenCardURL = "";

	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Данные.Свойство("uuid", UUIDСтроки);
		Данные.Свойство("kaiten_id", KaitenID);
		Данные.Свойство("external_status", ВнешнийСтатус);
		Данные.Свойство("kaiten_card_url", KaitenCardURL);
	КонецЕсли;

	UUIDСтроки = БезопаснаяСтрока(UUIDСтроки);
	KaitenID = БезопаснаяСтрока(KaitenID);
	ВнешнийСтатус = БезопаснаяСтрока(ВнешнийСтатус);
	KaitenCardURL = БезопаснаяСтрока(KaitenCardURL);

	Если ПустаяСтрока(UUIDСтроки) Тогда
		ВызватьИсключение "Не передан uuid";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задача КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();

		Если ОбъектДокумента.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаЗадачи Из ОбъектДокумента.Задачи Цикл

			Если БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки) <> UUIDСтроки Тогда
				Продолжить;
			КонецЕсли;

			СтрокаЗадачи.KaitenID = KaitenID;
			СтрокаЗадачи.ВнешнийСтатус = ВнешнийСтатус;
			СтрокаЗадачи.KaitenCardURL = KaitenCardURL;
			СтрокаЗадачи.ИзмененПослеСинхронизации = Ложь;
			СтрокаЗадачи.ДатаПоследнейСинхронизации = ТекущаяДата();

			ЗаписатьДокументТехнически(ОбъектДокумента);

			Возврат Истина;

		КонецЦикла;

	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция СоздатьИлиОбновитьЗадачуИзKaiten(Данные) Экспорт

	KaitenID = "";
	ВнешнийСтатус = "";
	KaitenCardURL = "";
	Заголовок = "";
	UUIDСтроки = "";
	ФактическаяТрудоемкость = 0;

	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Данные.Свойство("kaiten_id", KaitenID);
		Данные.Свойство("external_status", ВнешнийСтатус);
		Данные.Свойство("kaiten_card_url", KaitenCardURL);
		Данные.Свойство("title", Заголовок);
		Данные.Свойство("uuid", UUIDСтроки);
		Данные.Свойство("actual_hours", ФактическаяТрудоемкость);
	КонецЕсли;

	KaitenID = БезопаснаяСтрока(KaitenID);
	ВнешнийСтатус = БезопаснаяСтрока(ВнешнийСтатус);
	KaitenCardURL = БезопаснаяСтрока(KaitenCardURL);
	Заголовок = БезопаснаяСтрока(Заголовок);
	UUIDСтроки = БезопаснаяСтрока(UUIDСтроки);

	Если ПустаяСтрока(KaitenID) И ПустаяСтрока(UUIDСтроки) Тогда
		Возврат "";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задача КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();

		Если ОбъектДокумента.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаЗадачи Из ОбъектДокумента.Задачи Цикл

			НайденаСтрока = Ложь;

			Если НЕ ПустаяСтрока(KaitenID) Тогда
				Если БезопаснаяСтрока(СтрокаЗадачи.KaitenID) = KaitenID Тогда
					НайденаСтрока = Истина;
				КонецЕсли;
			КонецЕсли;

			Если НЕ НайденаСтрока И НЕ ПустаяСтрока(UUIDСтроки) Тогда
				Если БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки) = UUIDСтроки Тогда
					НайденаСтрока = Истина;
				КонецЕсли;
			КонецЕсли;

			Если НЕ НайденаСтрока Тогда
				Продолжить;
			КонецЕсли;

			Если НЕ ПустаяСтрока(KaitenID) Тогда
				СтрокаЗадачи.KaitenID = KaitenID;
			КонецЕсли;

			Если НЕ ПустаяСтрока(ВнешнийСтатус) Тогда
				СтрокаЗадачи.ВнешнийСтатус = ВнешнийСтатус;
			КонецЕсли;

			Если НЕ ПустаяСтрока(KaitenCardURL) Тогда
				СтрокаЗадачи.KaitenCardURL = KaitenCardURL;
			КонецЕсли;

			Если НЕ ПустаяСтрока(Заголовок) Тогда
				СтрокаЗадачи.Описание = Заголовок;
			КонецЕсли;

			Если ЗначениеЗаполнено(ФактическаяТрудоемкость) Тогда
				СтрокаЗадачи.ФактическаяТрудоемкость = ФактическаяТрудоемкость;
			КонецЕсли;

			ПопытатьсяЗаполнитьСтатус1СИзВнешнегоСтатуса(СтрокаЗадачи, ВнешнийСтатус);

			СтрокаЗадачи.ДатаПоследнейСинхронизации = ТекущаяДата();
			СтрокаЗадачи.ИзмененПослеСинхронизации = Ложь;

			ЗаписатьДокументСПроведением(ОбъектДокумента);

			Возврат БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки);

		КонецЦикла;

	КонецЦикла;

	Возврат "";

КонецФункции

Процедура ИсправитьДублиUUID() Экспорт

	ВстреченныеUUID = Новый Соответствие;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задача КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();

		Если ОбъектДокумента.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;

		НужноЗаписать = Ложь;

		Для Каждого СтрокаЗадачи Из ОбъектДокумента.Задачи Цикл

			ТекущийUUID = БезопаснаяСтрока(СтрокаЗадачи.UUIDСтроки);

			Если ПустаяСтрока(ТекущийUUID) Тогда
				СтрокаЗадачи.UUIDСтроки = Строка(Новый УникальныйИдентификатор());
				СтрокаЗадачи.ИзмененПослеСинхронизации = Истина;
				НужноЗаписать = Истина;
				Продолжить;
			КонецЕсли;

			Если ВстреченныеUUID.Получить(ТекущийUUID) <> Неопределено Тогда
				СтрокаЗадачи.UUIDСтроки = Строка(Новый УникальныйИдентификатор());
				СтрокаЗадачи.ИзмененПослеСинхронизации = Истина;
				НужноЗаписать = Истина;
			Иначе
				ВстреченныеUUID.Вставить(ТекущийUUID, Истина);
			КонецЕсли;

		КонецЦикла;

		Если НужноЗаписать Тогда
			ЗаписатьДокументТехнически(ОбъектДокумента);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Процедура ИнициализироватьНастройкиИнтеграцииKaitenПоСервисам() Экспорт

	УникальныеСервисы = Новый Соответствие;
	СуществующиеНастройки = Новый Соответствие;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИТСервисы_Задача КАК Док
	|ГДЕ
	|	НЕ Док.ПометкаУдаления";

	ВыборкаДокументов = Запрос.Выполнить().Выбрать();

	Пока ВыборкаДокументов.Следующий() Цикл

		ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();

		Если ОбъектДокумента.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаЗадачи Из ОбъектДокумента.Задачи Цикл

			Если НЕ ЗначениеЗаполнено(СтрокаЗадачи.ИТСервис) Тогда
				Продолжить;
			КонецЕсли;

			КлючСервиса = Строка(СтрокаЗадачи.Предмет.УникальныйИдентификатор());

			Если УникальныеСервисы.Получить(КлючСервиса) = Неопределено Тогда
				УникальныеСервисы.Вставить(КлючСервиса, СтрокаЗадачи.ИТСервис);
			КонецЕсли;

		КонецЦикла;

	КонецЦикла;

	ЗапросНастроек = Новый Запрос;
	ЗапросНастроек.Текст =
	"ВЫБРАТЬ
	|	Настройки.Предмет КАК Предмет
	|ИЗ
	|	РегистрСведений.ИТСервисы_НастройкиИнтеграцииKaiten КАК Настройки
	|ГДЕ
	|	Настройки.ExternalSystemCode = &ExternalSystemCode
	|	ИЛИ Настройки.ExternalSystemCode = &EmptyCode";

	ЗапросНастроек.УстановитьПараметр("ExternalSystemCode", "KAITEN");
	ЗапросНастроек.УстановитьПараметр("EmptyCode", "");

	ВыборкаНастроек = ЗапросНастроек.Выполнить().Выбрать();

	Пока ВыборкаНастроек.Следующий() Цикл
		КлючСервиса = Строка(ВыборкаНастроек.Предмет.УникальныйИдентификатор());
		СуществующиеНастройки.Вставить(КлючСервиса, Истина);
	КонецЦикла;

	НаборЗаписей = РегистрыСведений.ИТСервисы_НастройкиИнтеграцииKaiten.СоздатьНаборЗаписей();

	Для Каждого ЭлементСервиса Из УникальныеСервисы Цикл

		КлючСервиса = ЭлементСервиса.Ключ;
		ИТСервис = ЭлементСервиса.Значение;

		Если СуществующиеНастройки.Получить(КлючСервиса) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Предмет = ИТСервис;
		НоваяЗапись.Активно = Ложь;
		НоваяЗапись.KaitenBoardID = 0;
		НоваяЗапись.KaitenLaneID = 0;
		НоваяЗапись.KaitenQueueColumnID = 0;
		НоваяЗапись.KaitenInProgressColumnID = 0;
		НоваяЗапись.KaitenReviewColumnID = 0;
		НоваяЗапись.KaitenDoneColumnID = 0;
		НоваяЗапись.KaitenCanceledColumnID = 0;
		НоваяЗапись.PriorityPropertyID = 0;
		НоваяЗапись.PlanHoursPropertyID = 0;
		НоваяЗапись.FactHoursPropertyID = 0;
		НоваяЗапись.ServicePropertyID = 0;
		НоваяЗапись.StartDatePropertyID = 0;
		НоваяЗапись.EndDatePropertyID = 0;
		НоваяЗапись.ExternalSystemCode = "KAITEN";

	КонецЦикла;

	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Записать();
	КонецЕсли;

КонецПроцедуры


Функция ПолучитьНастройкиИнтеграцииKaiten() Экспорт

	ИнициализироватьНастройкиИнтеграцииKaitenПоСервисам();

	РезультатПоСервисам = Новый Соответствие;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Настройки.Предмет КАК Предмет,
	|	Настройки.Активно КАК Активно,
	|	Настройки.KaitenBoardID КАК KaitenBoardID,
	|	Настройки.KaitenLaneID КАК KaitenLaneID,
	|	Настройки.KaitenQueueColumnID КАК KaitenQueueColumnID,
	|	Настройки.KaitenInProgressColumnID КАК KaitenInProgressColumnID,
	|	Настройки.KaitenReviewColumnID КАК KaitenReviewColumnID,
	|	Настройки.KaitenDoneColumnID КАК KaitenDoneColumnID,
	|	Настройки.KaitenCanceledColumnID КАК KaitenCanceledColumnID,
	|	Настройки.PriorityPropertyID КАК PriorityPropertyID,
	|	Настройки.PlanHoursPropertyID КАК PlanHoursPropertyID,
	|	Настройки.FactHoursPropertyID КАК FactHoursPropertyID,
	|	Настройки.ServicePropertyID КАК ServicePropertyID,
	|	Настройки.StartDatePropertyID КАК StartDatePropertyID,
	|	Настройки.EndDatePropertyID КАК EndDatePropertyID,
	|	Настройки.ExternalSystemCode КАК ExternalSystemCode
	|ИЗ
	|	РегистрСведений.ИТСервисы_НастройкиИнтеграцииKaiten КАК Настройки
	|ГДЕ
	|	Настройки.ExternalSystemCode = &ExternalSystemCode
	|	ИЛИ Настройки.ExternalSystemCode = &EmptyCode";
	
	Запрос.УстановитьПараметр("ExternalSystemCode", "KAITEN");
	Запрос.УстановитьПараметр("EmptyCode", "");


	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		КлючСервиса = Строка(Выборка.Предмет.УникальныйИдентификатор());

		Стр = Новый Структура;
		Стр.Вставить("service_ref", КлючСервиса);
		Стр.Вставить("service_name", БезопаснаяСтрока(Выборка.ИТСервис));
		Стр.Вставить("active", Выборка.Активно);
		Стр.Вставить("board_id", Выборка.KaitenBoardID);
		Стр.Вставить("lane_id", Выборка.KaitenLaneID);
		Стр.Вставить("_external_system_code", БезопаснаяСтрока(Выборка.ExternalSystemCode));

		Колонки = Новый Структура;
		Колонки.Вставить("queue", Выборка.KaitenQueueColumnID);
		Колонки.Вставить("in_progress", Выборка.KaitenInProgressColumnID);
		Колонки.Вставить("review", Выборка.KaitenReviewColumnID);
		Колонки.Вставить("done", Выборка.KaitenDoneColumnID);
		Колонки.Вставить("canceled", Выборка.KaitenCanceledColumnID);
		Стр.Вставить("columns", Колонки);

		Свойства = Новый Структура;
		Свойства.Вставить("priority", Выборка.PriorityPropertyID);
		Свойства.Вставить("plan_hours", Выборка.PlanHoursPropertyID);
		Свойства.Вставить("fact_hours", Выборка.FactHoursPropertyID);
		Свойства.Вставить("service", Выборка.ServicePropertyID);
		Свойства.Вставить("start_date", Выборка.StartDatePropertyID);
		Свойства.Вставить("end_date", Выборка.EndDatePropertyID);
		Стр.Вставить("properties", Свойства);

		СуществующаяСтрока = РезультатПоСервисам.Получить(КлючСервиса);

		Если СуществующаяСтрока = Неопределено Тогда
			РезультатПоСервисам.Вставить(КлючСервиса, Стр);
			Продолжить;
		КонецЕсли;

		Если ПустаяСтрока(БезопаснаяСтрока(СуществующаяСтрока._external_system_code))
			И НЕ ПустаяСтрока(БезопаснаяСтрока(Стр._external_system_code)) Тогда
			РезультатПоСервисам.Вставить(КлючСервиса, Стр);
		КонецЕсли;

	КонецЦикла;

	Результат = Новый Массив;

	Для Каждого Элемент Из РезультатПоСервисам Цикл
		Стр = Элемент.Значение;
		Стр.Удалить("_external_system_code");
		Результат.Добавить(Стр);
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ОбновитьНастройкиИнтеграцииKaiten(СписокНастроек) Экспорт

	Если ТипЗнч(СписокНастроек) <> Тип("Массив") Тогда
		ВызватьИсключение "Ожидался массив настроек";
	КонецЕсли;

	Для Каждого Элемент Из СписокНастроек Цикл

		Если ТипЗнч(Элемент) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;

		ServiceRef = Неопределено;
		Active = Ложь;
		BoardID = 0;
		LaneID = 0;
		Columns = Неопределено;
		Properties = Неопределено;

		Элемент.Свойство("service_ref", ServiceRef);
		Элемент.Свойство("active", Active);
		Элемент.Свойство("board_id", BoardID);
		Элемент.Свойство("lane_id", LaneID);
		Элемент.Свойство("columns", Columns);
		Элемент.Свойство("properties", Properties);

		Если НЕ ЗначениеЗаполнено(ServiceRef) Тогда
			Продолжить;
		КонецЕсли;

		Попытка
			СсылкаСервиса = Справочники.ИТСервисы_ИТСервисы.ПолучитьСсылку(Новый УникальныйИдентификатор(ServiceRef));
		Исключение
			Продолжить;
		КонецПопытки;

		Если НЕ ЗначениеЗаполнено(СсылкаСервиса) Тогда
			Продолжить;
		КонецЕсли;

		НаборЗаписей = РегистрыСведений.ИТСервисы_НастройкиИнтеграцииKaiten.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Предмет.Установить(СсылкаСервиса);
		НаборЗаписей.Прочитать();

		Если НаборЗаписей.Количество() = 0 Тогда
		    НоваяЗапись = НаборЗаписей.Добавить();
		    НоваяЗапись.Предмет = СсылкаСервиса;
		Иначе
		    НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;

		НоваяЗапись.ExternalSystemCode = "KAITEN";

		НоваяЗапись.Активно = Active;
		НоваяЗапись.KaitenBoardID = BoardID;
		НоваяЗапись.KaitenLaneID = LaneID;

		Если ТипЗнч(Columns) = Тип("Структура") Тогда
			QueueID = 0;
			InProgressID = 0;
			ReviewID = 0;
			DoneID = 0;
			CanceledID = 0;

			Columns.Свойство("queue", QueueID);
			Columns.Свойство("in_progress", InProgressID);
			Columns.Свойство("review", ReviewID);
			Columns.Свойство("done", DoneID);
			Columns.Свойство("canceled", CanceledID);

			НоваяЗапись.KaitenQueueColumnID = QueueID;
			НоваяЗапись.KaitenInProgressColumnID = InProgressID;
			НоваяЗапись.KaitenReviewColumnID = ReviewID;
			НоваяЗапись.KaitenDoneColumnID = DoneID;
			НоваяЗапись.KaitenCanceledColumnID = CanceledID;
		КонецЕсли;

		Если ТипЗнч(Properties) = Тип("Структура") Тогда
			PriorityID = 0;
			PlanHoursID = 0;
			FactHoursID = 0;
			ServicePropertyID = 0;
			StartDateID = 0;
			EndDateID = 0;

			Properties.Свойство("priority", PriorityID);
			Properties.Свойство("plan_hours", PlanHoursID);
			Properties.Свойство("fact_hours", FactHoursID);
			Properties.Свойство("service", ServicePropertyID);
			Properties.Свойство("start_date", StartDateID);
			Properties.Свойство("end_date", EndDateID);

			НоваяЗапись.PriorityPropertyID = PriorityID;
			НоваяЗапись.PlanHoursPropertyID = PlanHoursID;
			НоваяЗапись.FactHoursPropertyID = FactHoursID;
			НоваяЗапись.ServicePropertyID = ServicePropertyID;
			НоваяЗапись.StartDatePropertyID = StartDateID;
			НоваяЗапись.EndDatePropertyID = EndDateID;
		КонецЕсли;

		НаборЗаписей.Записать();

	КонецЦикла;

	Возврат Истина;

КонецФункции



