&НаКлиенте
Процедура ПрограммныеОбеспеченияПрограммноеОбеспечениеПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ПрограммныеОбеспечения.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И ТекущиеДанные.ПрограммноеОбеспечение <> Неопределено Тогда
		ПроверитьЛицензиюПО(ТекущиеДанные.ПрограммноеОбеспечение);
	КонецЕсли;
	
	СтрокаТаблицы = Элементы.ПрограммныеОбеспечения.ТекущиеДанные;
	
	Если СтрокаТаблицы <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицы.ПрограммноеОбеспечение) Тогда
		ПараметрыОтбора = Новый Структура("ПрограммноеОбеспечение", СтрокаТаблицы.ПрограммноеОбеспечение);
		НайденныеСтроки = Объект.ПрограммныеОбеспечения.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтроки.Количество() > 1 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"Это программное обеспечение уже добавлено в список!", , 
				"Объект.ПрограммныеОбеспечения[" + Объект.ПрограммныеОбеспечения.Индекс(СтрокаТаблицы) + "].ПрограммноеОбеспечение");

			СтрокаТаблицы.ПрограммноеОбеспечение = Неопределено;
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЛицензиюПО(ПрограммноеОбеспечение)

	РезультатПроверки = ПроверитьЛицензиюПОНаСервере(ПрограммноеОбеспечение);

	Если Не РезультатПроверки.ЕстьДействующаяЛицензия Тогда
		Если Не РезультатПроверки.ЕстьЛицензия Тогда
			ТекстСообщения = "Для программного обеспечения """ + ПрограммноеОбеспечение
				+ """ нет лицензии. Добавление невозможно.";
			ПоказатьПредупреждение(, ТекстСообщения, , "Добавление ПО");
		Иначе
			ТекстСообщения = "Для программного обеспечения """ + ПрограммноеОбеспечение
				+ """ срок действия всех лицензий истёк. Добавление невозможно.";
			ПоказатьПредупреждение(, ТекстСообщения, , "Добавление ПО");
		КонецЕсли;

		ТекущиеДанные = Элементы.ПрограммныеОбеспечения.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			ТекущиеДанные.ПрограммноеОбеспечение = Неопределено;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьЛицензиюПОНаСервере(Знач ПрограммноеОбеспечение)

	Результат = Новый Структура("ЕстьДействующаяЛицензия, ЕстьЛицензия", Ложь, Ложь);

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИТСервисы_ЛицензииПО.Ссылка КАК Лицензия,
	|	ИТСервисы_ЛицензииПО.ДатаНачала КАК ДатаНачала,
	|	ИТСервисы_ЛицензииПО.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Справочник.ИТСервисы_ЛицензииПО КАК ИТСервисы_ЛицензииПО
	|ГДЕ
	|	ИТСервисы_ЛицензииПО.ПрограммноеОбеспечение = &ПрограммноеОбеспечение
	|	И НЕ ИТСервисы_ЛицензииПО.ПометкаУдаления";

	Запрос.УстановитьПараметр("ПрограммноеОбеспечение", ПрограммноеОбеспечение);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		Результат.ЕстьЛицензия = Истина;

		ТекущаяДата = ТекущаяДатаСеанса();

		Если Выборка.ДатаНачала <> Неопределено И Выборка.ДатаОкончания <> Неопределено Тогда
			Если ТекущаяДата >= Выборка.ДатаНачала И ТекущаяДата <= Выборка.ДатаОкончания Тогда
				Результат.ЕстьДействующаяЛицензия = Истина;
				Прервать;
			КонецЕсли;
		ИначеЕсли Выборка.ДатаОкончания = Неопределено Тогда
			Если Выборка.ДатаНачала = Неопределено ИЛИ ТекущаяДата >= Выборка.ДатаНачала Тогда
				Результат.ЕстьДействующаяЛицензия = Истина;
				Прервать;
			Иначе
				Продолжить;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    ОбработатьВидимостьКонтрагента();
    ОбработатьВидимостьДатыВывода();
    СписокПроектов.Параметры.УстановитьЗначениеПараметра("ТекущийСервис", Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ВнешнийСервисПриИзменении(Элемент)
    ОбработатьВидимостьКонтрагента();
КонецПроцедуры

&НаКлиенте
Процедура АктивенПриИзменении(Элемент)
    ОбработатьВидимостьДатыВывода();
КонецПроцедуры

&НаСервере
Процедура ОбработатьВидимостьКонтрагента()
    Если НЕ Объект.ВнешнийСервис Тогда
        Объект.ДоговорСТП = Справочники.Контрагенты.ПустаяСсылка();
    КонецЕсли;
    Элементы.ДоговорСТП.Видимость = Объект.ВнешнийСервис;
КонецПроцедуры

&НаСервере
Процедура ОбработатьВидимостьДатыВывода()
    Если Объект.Активен Тогда
        Объект.ДатаВывода = Дата(1, 1, 1);
    КонецЕсли;
    Элементы.ДатаВывода.Видимость = НЕ Объект.Активен;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
    Если Объект.ДатаВывода <> Дата(1, 1, 1) И Объект.ДатаВывода < Объект.ДатаЗапуска Тогда
        Отказ = Истина;
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = "Дата вывода не может быть меньше даты запуска!";
        Сообщение.Сообщить();
    КонецЕсли;
КонецПроцедуры