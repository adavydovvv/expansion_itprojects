
&НаКлиенте
Процедура ДатаВыводаПриИзменении(Элемент)
	
	ПроверитьДаты();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаЗапускаПриИзменении(Элемент)
	
	ПроверитьДаты();
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДаты()

	ДатаЗапуска = Объект.ДатаЗапуска;
	ДатаВывода = Объект.ДатаВывода;

	Если Не ДатаЗапуска = Неопределено И Не ДатаВывода = Неопределено Тогда
		Если ДатаВывода < ДатаЗапуска Тогда
			Сообщить("Дата вывода не может быть меньше даты запуска", СтатусСообщения.Внимание);
			Объект.ДатаВывода = ДатаЗапуска;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПрограммныеОбеспеченияПрограммноеОбеспечениеПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ПрограммныеОбеспечения.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И ТекущиеДанные.ПрограммноеОбеспечение <> Неопределено Тогда
		ПроверитьЛицензиюПО(ТекущиеДанные.ПрограммноеОбеспечение);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЛицензиюПО(ПрограммноеОбеспечение)

	РезультатПроверки = ПроверитьЛицензиюПОНаСервере(ПрограммноеОбеспечение);

	Если Не РезультатПроверки.ЕстьДействующаяЛицензия Тогда
		Если Не РезультатПроверки.ЕстьЛицензия Тогда
			ТекстСообщения = "Для программного обеспечения """ + ПрограммноеОбеспечение
				+ """ нет лицензии. Добавление невозможно.";
			ПоказатьПредупреждение(, ТекстСообщения, , "Добавление ПО");
		Иначе
			ТекстСообщения = "Для программного обеспечения """ + ПрограммноеОбеспечение
				+ """ срок действия всех лицензий истёк. Добавление невозможно.";
			ПоказатьПредупреждение(, ТекстСообщения, , "Добавление ПО");
		КонецЕсли;

		ТекущиеДанные = Элементы.ПрограммныеОбеспечения.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			ТекущиеДанные.ПрограммноеОбеспечение = Неопределено;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьЛицензиюПОНаСервере(Знач ПрограммноеОбеспечение)

	Результат = Новый Структура("ЕстьДействующаяЛицензия, ЕстьЛицензия", Ложь, Ложь);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИТСервисы_ЛицензииПО.Ссылка КАК Лицензия,
	|	ИТСервисы_ЛицензииПО.ДатаНачала КАК ДатаНачала,
	|	ИТСервисы_ЛицензииПО.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Справочник.ИТСервисы_ЛицензииПО КАК ИТСервисы_ЛицензииПО
	|ГДЕ
	|	ИТСервисы_ЛицензииПО.ПрограммноеОбеспечение = &ПрограммноеОбеспечение
	|	И НЕ ИТСервисы_ЛицензииПО.ПометкаУдаления";

	Запрос.УстановитьПараметр("ПрограммноеОбеспечение", ПрограммноеОбеспечение);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		Результат.ЕстьЛицензия = Истина;

		ТекущаяДата = ТекущаяДатаСеанса();

		Если Выборка.ДатаНачала <> Неопределено И Выборка.ДатаОкончания <> Неопределено Тогда
			Если ТекущаяДата >= Выборка.ДатаНачала И ТекущаяДата <= Выборка.ДатаОкончания Тогда
				Результат.ЕстьДействующаяЛицензия = Истина;
				Прервать;
			КонецЕсли;
		ИначеЕсли Выборка.ДатаОкончания = Неопределено Тогда
			Если Выборка.ДатаНачала = Неопределено ИЛИ ТекущаяДата >= Выборка.ДатаНачала Тогда
				Результат.ЕстьДействующаяЛицензия = Истина;
				Прервать;
			Иначе
				Продолжить;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции
