&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗагрузитьНастройкиНаСервере();
КонецПроцедуры


&НаСервере
Процедура ЗагрузитьНастройкиНаСервере()

	KaitenBaseUrl = СокрЛП(Константы.ИТСервисы_KaitenBaseUrl.Получить());
	KaitenToken = СокрЛП(Константы.ИТСервисы_KaitenToken.Получить());
	PythonServiceUrl = СокрЛП(Константы.ИТСервисы_PythonServiceUrl.Получить());
	KaitenIntegrationEnabled = Константы.ИТСервисы_KaitenIntegrationEnabled.Получить();
	KaitenSyncIntervalMinutes = Константы.ИТСервисы_KaitenSyncIntervalMinutes.Получить();

КонецПроцедуры


&НаСервере
Процедура СохранитьНастройкиНаСервере()

	Если ПустаяСтрока(СокрЛП(PythonServiceUrl)) Тогда
		ВызватьИсключение "Не заполнен адрес Python-сервиса.";
	КонецЕсли;

	Если KaitenIntegrationEnabled И ПустаяСтрока(СокрЛП(KaitenBaseUrl)) Тогда
		ВызватьИсключение "Не заполнен URL Kaiten.";
	КонецЕсли;

	Если KaitenIntegrationEnabled И ПустаяСтрока(СокрЛП(KaitenToken)) Тогда
		ВызватьИсключение "Не заполнен токен Kaiten.";
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(KaitenSyncIntervalMinutes) Тогда
		KaitenSyncIntervalMinutes = 15;
	КонецЕсли;

	Если KaitenSyncIntervalMinutes <= 0 Тогда
		ВызватьИсключение "Интервал синхронизации должен быть больше нуля.";
	КонецЕсли;

	Константы.ИТСервисы_KaitenBaseUrl.Установить(СокрЛП(KaitenBaseUrl));
	Константы.ИТСервисы_KaitenToken.Установить(СокрЛП(KaitenToken));
	Константы.ИТСервисы_PythonServiceUrl.Установить(СокрЛП(PythonServiceUrl));
	Константы.ИТСервисы_KaitenIntegrationEnabled.Установить(KaitenIntegrationEnabled);
	Константы.ИТСервисы_KaitenSyncIntervalMinutes.Установить(KaitenSyncIntervalMinutes);

КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	Попытка
		ЗагрузитьНастройкиНаСервере();
		Элементы.KaitenBaseUrl.Обновить();
		Элементы.KaitenToken.Обновить();
		Элементы.PythonServiceUrl.Обновить();
		Элементы.KaitenIntegrationEnabled.Обновить();
		Элементы.KaitenSyncIntervalMinutes.Обновить();
		Сообщить("Настройки загружены.");
	Исключение
		Сообщить("Ошибка загрузки: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры


&НаКлиенте
Процедура Сохранить(Команда)
	Попытка
		СохранитьНастройкиНаСервере();
		Сообщить("Настройки интеграции сохранены.");
	Исключение
		Сообщить("Ошибка сохранения: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

