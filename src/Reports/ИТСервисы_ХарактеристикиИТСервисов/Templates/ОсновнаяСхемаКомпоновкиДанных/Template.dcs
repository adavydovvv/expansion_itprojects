<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ИТСервис</dataPath>
			<field>ИТСервис</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СервисНаименование</dataPath>
			<field>СервисНаименование</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сервис наименование</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НаРазвитии</dataPath>
			<field>НаРазвитии</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НаСопровождении</dataPath>
			<field>НаСопровождении</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПланВИСУП</dataPath>
			<field>ПланВИСУП</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>План ВИСУП</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДорожнаяКарта</dataPath>
			<field>ДорожнаяКарта</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПриказВвод</dataPath>
			<field>ПриказВвод</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Приказ ввод</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Паспорт</dataPath>
			<field>Паспорт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Паспорт</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Архитектура</dataPath>
			<field>Архитектура</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>БазаЗнаний</dataPath>
			<field>БазаЗнаний</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РуководительСервиса</dataPath>
			<field>РуководительСервиса</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Руководитель сервиса</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДоговорТПНомер</dataPath>
			<field>ДоговорТПНомер</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Договор ТПНомер</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДоговорТПДатаОкончание</dataPath>
			<field>ДоговорТПДатаОкончание</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Договор ТПДата окончание</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КодВАРМРазработчика</dataPath>
			<field>КодВАРМРазработчика</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Код ВАРМРазработчика</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ИТСервисы.Ссылка КАК ИТСервис,
	ИТСервисы.Наименование КАК СервисНаименование,
	ВЫБОР
		КОГДА ИТСервисы.Развитие = ИСТИНА ТОГДА "Да"
		КОГДА ИТСервисы.Развитие = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК НаРазвитии,
	ВЫБОР
		КОГДА ИТСервисы.Сопровождение = ИСТИНА ТОГДА "Да"
		КОГДА ИТСервисы.Сопровождение = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК НаСопровождении,
	ВЫБОР
		КОГДА ИТСервисы.ПланПроектаВИСУП = ИСТИНА ТОГДА "Да"
		КОГДА ИТСервисы.ПланПроектаВИСУП = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК ПланВИСУП,
	ВЫБОР
		КОГДА Парам.ДорожнаяКарта = ИСТИНА ТОГДА "Да"
		КОГДА Парам.ДорожнаяКарта = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК ДорожнаяКарта,
	ВЫБОР
		КОГДА Парам.ПаспортСервиса = ИСТИНА ТОГДА "Да"
		КОГДА Парам.ПаспортСервиса = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК Паспорт,
	ВЫБОР
		КОГДА Парам.Архитектура = ИСТИНА ТОГДА "Да"
		КОГДА Парам.Архитектура = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК Архитектура,
	ВЫБОР
		КОГДА Парам.БазаЗнаний = ИСТИНА ТОГДА "Да"
		КОГДА Парам.БазаЗнаний = ЛОЖЬ ТОГДА "Нет"
		ИНАЧЕ "-"
	КОНЕЦ КАК БазаЗнаний,
	ИТСервисы.Руководитель КАК РуководительСервиса,
	ВЫБОР
		КОГДА ИТСервисы.КодВАРМРазработчика &lt;&gt; "" ТОГДА ИТСервисы.КодВАРМРазработчика
		ИНАЧЕ "-"
	КОНЕЦ КАК КодВАРМРазработчика,
	Парам.ДоговорТП.НомерДоговораУТП КАК ДоговорТПНомер,
	Парам.ДоговорТП.ДатаОкончание КАК ДоговорТПДатаОкончание,
	Парам.ПриказОВводеВПЭ.Номер КАК ПриказВвод
ИЗ
	Справочник.ИТСервисы_ИТСервисы КАК ИТСервисы
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИТСервисы_ПараметрыИТСервисов.СрезПоследних(&amp;Период, ) КАК Парам
		ПО ИТСервисы.Ссылка = Парам.ИТСервис
ГДЕ
	ИТСервисы.ПометкаУдаления = ЛОЖЬ

УПОРЯДОЧИТЬ ПО
	СервисНаименование</query>
	</dataSet>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
	</parameter>
	<template>
		<name>Макет1</name>
		<template xmlns:dcsat="http://v8.1c.ru/8.1/data-composition-system/area-template" xsi:type="dcsat:AreaTemplate">
