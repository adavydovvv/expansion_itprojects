		<field xsi:type="DataSetFieldField">
			<dataPath>ЗадачаОписание</dataPath>
			<field>ЗадачаОписание</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СостоянияЗадач.Проект.Ссылка КАК Проект,
	СостоянияЗадач.Исполнитель.Ссылка КАК Исполнитель,
	СостоянияЗадач.Задача.Ссылка КАК Задача,
	СостоянияЗадач.Приоритет КАК Приоритет,
	СостоянияЗадач.Статус КАК СтатусВнутренний,
	СостоянияЗадач.ПлановаяТрудоемкость КАК ПлановаяТрудоемкость,
	СостоянияЗадач.ФактическаяТрудоемкость КАК ФактическаяТрудоемкость,
	РАЗНОСТЬДАТ(СостоянияЗадач.ДатаНачала, СостоянияЗадач.ДатаОкончания, ДЕНЬ) КАК ДнейВРаботе,
	СостоянияЗадач.Задача.Описание КАК ЗадачаОписание
ИЗ
	РегистрСведений.ИТСервисы_СостоянияЗадач.СрезПоследних КАК СостоянияЗадач</query>
	</dataSet>
